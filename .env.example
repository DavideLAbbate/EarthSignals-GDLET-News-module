# ── Google Cloud / BigQuery ───────────────────────────────────────────────
# Path to your GCP service account JSON key file (inside the container)
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-key.json
GCP_PROJECT_ID=your-gcp-project-id
BQ_MAX_RESULTS=500
MAX_BQ_SCAN_DAYS=3650
BQ_EXECUTOR_MAX_WORKERS=4

# ── Anthropic ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5
ANTHROPIC_TIMEOUT_SECONDS=30
ANTHROPIC_MAX_RETRIES=3

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_USER=gdelt_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=gdelt_db
DATABASE_URL=postgresql+asyncpg://gdelt_user:changeme@db:5432/gdelt_db

# ── App / Security ────────────────────────────────────────────────────────
API_KEY=your-secret-api-key-here
CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
APP_ENV=production

# ── Scheduler ─────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=15

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
