# ── Required ──────────────────────────────────────────────────────────────
# Anthropic API key — used to normalize free-text search filters.
ANTHROPIC_API_KEY=sk-ant-...
# Secret the frontend sends as the `X-API-Key` header on every protected route.
API_KEY=change-me-to-a-long-random-secret

# ── Database ──────────────────────────────────────────────────────────────
# With docker-compose, DATABASE_URL is built automatically from the POSTGRES_*
# values below — you usually only need to edit these three.
POSTGRES_USER=gdelt_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=gdelt_db
# For local (non-Docker) runs, set the async URL directly instead:
# DATABASE_URL=postgresql+asyncpg://gdelt_user:changeme@localhost:5432/gdelt_db

# ── Anthropic (optional) ──────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-opus-4-5
ANTHROPIC_TIMEOUT_SECONDS=30
ANTHROPIC_MAX_RETRIES=3

# ── LLM enrichment microservice (optional) ────────────────────────────────
# External service that wraps a local LLM (Ollama in the reference setup) and
# turns clustered articles into title/summary/topics/entities.
EVENT_ENRICHMENT_SERVICE_BASE_URL=http://localhost:8001
EVENT_ENRICHMENT_SERVICE_TIMEOUT_SECONDS=10
ENABLE_EVENT_ENRICHMENT=false
ENABLE_CLUSTER_ENRICHMENT=false

# ── App / security (optional) ─────────────────────────────────────────────
# JSON array of allowed CORS origins (frontend URLs).
CORS_ORIGINS=["http://localhost:3000"]
APP_ENV=production
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=10

# ── Background jobs (optional) ────────────────────────────────────────────
ENABLE_METADATA_SYNC=true
SYNC_INTERVAL_MINUTES=15
INGESTION_INTERVAL_MINUTES=60
RETENTION_DAYS=30
ENABLE_CLUSTER_MATERIALISATION=true
CLUSTER_INTERVAL_MINUTES=1440

# Cluster pipeline tuning knobs (merge thresholds, candidate gates, GKG caps,
# retention) all have sensible defaults — see app/core/config.py to override.
